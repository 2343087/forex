# ═══════════════════════════════════════
# APEX ELITE — .gitignore
# ═══════════════════════════════════════

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Environment files (JANGAN SAMPAI KE-PUSH!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env.local

# Database
*.db
*.sqlite

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Prisma
backend/prisma/migrations/

# Uploads (user-generated content)
public/uploads/*
!public/uploads/.gitkeep

# PWA generated
sw.js.map

# Misc
*.tsbuildinfo
next-env.d.ts
